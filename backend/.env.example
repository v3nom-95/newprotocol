APP_NAME=Q-AI Chain API
ENVIRONMENT=dev
DATABASE_URL=postgresql+psycopg://qai:qai@postgres:5432/qai_chain
REDIS_URL=redis://redis:6379/0
MODEL_PATH=../ai-engine/artifacts/isolation_forest.joblib
FEATURE_SCALER_PATH=../ai-engine/artifacts/scaler.joblib
AES_MASTER_KEY=replace_with_random_secret
RPC_URL=https://sepolia.infura.io/v3/your-key
RELAYER_PRIVATE_KEY=0xyour_relayer_private_key
JWT_SECRET=replace_with_very_strong_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=30
JWT_REFRESH_TOKEN_EXP_DAYS=7
PRODUCTION_MODE=false
AI_DRIFT_THRESHOLD=2.5
RISK_CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
METRICS_TOKEN=
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
TX_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
RISK_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT=120/minute
